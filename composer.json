{
    "name": "medichain/healthvault-secure",
    "description": "Secure refactoring of the HealthVault-API breach vectors (SECR4483 Alternative Assessment).",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "HealthVault\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
